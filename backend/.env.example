# LLM Provider Configuration
LLM_PROVIDER=openai  # claude, openai, or vertex
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Model Configuration
CLAUDE_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# Database (Docker: use /app/data/ for volume persistence)
DATABASE_URL=sqlite+aiosqlite:///./data/ai_pathway.db

# ChromaDB (Docker: use /app/data/ for volume persistence)
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Server
HOST=0.0.0.0
PORT=8080
DEBUG=false

# CORS (comma-separated origins)
CORS_ORIGINS=http://95.216.199.47,http://localhost:5173
